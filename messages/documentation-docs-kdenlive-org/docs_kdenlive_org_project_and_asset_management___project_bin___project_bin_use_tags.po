#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:29
msgid "Using Tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:31
msgid "Tags are a good way to stay organized as they give you a quick overview of the nature of your assets. You can create as many tags as you need, assign different colors, and change the default tags. After you assigned tags to your assets you can then quickly filter by tags making it much easier to assemble the clips in the timeline and building your story."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:34
msgid "Kdenlive adjusts the width of the project bin widget to accommodate all tags and their description. It is recommended to keep the number of tags and the length of the description as small as possible to conserve valuable screen real estate for other widgets (in particular the timeline and monitors). If you have multiple monitors at your disposal consider undocking some of the widgets and moving them off the main screen used for editing."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:43
msgid "Enabling the tags panel"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:45
msgid "Click on the |tag|\\ :guilabel:`Tags Panel` icon in the project bin toolbar to enable the panel."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:51
msgid "Assigning Tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:55
msgid "Assigning tags is as simple as selecting a clip and then clicking the appropriate tag in the panel."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:64
msgid "Assigning tags to clips"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:66
msgid "A clip can have more than one tag."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:68
msgid "Click the tag again to remove it from the clip"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:76
msgid "Editing Tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:85
msgid "Editing tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:87
msgid "You can change the description and color of existing tags."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:89
msgid "Click on |edit-delete|\\ :guilabel:`Delete` to delete a tag."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:91
msgid "Click on |tag-add|\\ :guilabel:`Add tag` to add a new tag."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:93
msgid "Make sure to click |document-save|\\ :guilabel:`Save` to save the changes."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:98
msgid "You can change the order of the tags in the panel by simply grabbing a tag and dragging it to the desired place in the panel."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:102
msgid "Filtering by Tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:104
msgid "You can filter the project bin list using tags."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:112
msgid "Filtering using tags"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:114
msgid "Note how the background of the |view-filter|\\ icon changes as soon as filter criteria have been selected."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:116
msgid "Filter criteria within the same category (like *tag* or *rating*) are applied in an OR fashion, meaning that all clips with any of the selected criteria will be listed (red OR green *tag*)."
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:118
msgid "Filter criteria across different categories are applied in an AND fashion, meaning that clips with criteria from both categories will be listed (red OR green *tag* AND with four OR five *stars*)"
msgstr ""

#. +> trunk5
#: ../../project_and_asset_management/project_bin/project_bin_use_tags.rst:120
msgid "For more details refer to the chapter about :doc:`using filters</project_and_asset_management/project_bin/project_bin_use_filters>`."
msgstr ""

