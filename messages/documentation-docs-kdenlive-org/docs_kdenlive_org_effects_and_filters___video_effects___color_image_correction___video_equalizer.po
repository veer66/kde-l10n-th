#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:53
msgid "Value"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:55
msgid "Contrast"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:56
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:59
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:62
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:65
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:68
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:71
msgid "Float"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:57
msgid "Set the contrast expression. Negative values give a negative image. The value must be a float value in range -3.00 to 3.00. The default value is 1.00."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:58
msgid "Brightness"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:60
msgid "Set the brightness expression. The value must be a float value in range -1.00 to 1.00. The default value is 0.00."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:61
msgid "Saturation"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:63
msgid "Set the saturation expression. The value must be a float in range 0.00 to 5.00. The default value is 1.00."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:64
msgid "Gamma"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:66
msgid "Set the gamma expression. The value must be a float in range 0.00 to 3.00. The default value is 1.00."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:67
msgid "Red / Green / Blue Gamma"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:69
msgid "Set the gamma expression for red, green or blue. The value must be a float in range 0.00 to 3.00. The default value is 1.00."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:70
msgid "Gamma Weight"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:72
msgid "Set the gamma weight expression. It can be used to reduce the effect of a high gamma value on bright image areas, e.g. keep them from getting over amplified and just plain white. The value must be a float in range 0.00 to 1.00. A value of 0.0 turns the gamma correction all the way down while 1.00 leaves it at its full strength. Default is 1.00."
msgstr ""

