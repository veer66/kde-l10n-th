#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:41
msgid "This effect/filter sets brightness, contrast, :term:`saturation` and approximate :term:`gamma` adjustment."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:45
msgid "Parameters"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/color_image_correction/video_equalizer.rst:52
msgid "Parameter"
