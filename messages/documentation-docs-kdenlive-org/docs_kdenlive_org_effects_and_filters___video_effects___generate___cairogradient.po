#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:106
msgid "Normal"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:107
msgid "This is the default attribute which specifies no blending. The blending formula simply selects the source color."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:108
msgid "Add"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:110
msgid "Saturate"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:112
msgid "Multiply"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:113
msgid "The source color is multiplied by the destination color and replaces the destination. The resultant color is always at least as dark as either the source or destination color. Multiplying any color with black results in black. Multiplying any color with white preserves the original color."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:114
msgid "Screen"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:115
msgid "Multiplies the complements of the backdrop and source color values, then complements the result. The result color is always at least as light as either of the two constituent colors. Screening any color with white produces white; screening with black leaves the original color unchanged. The effect is similar to projecting multiple photographic slides simultaneously onto a single screen."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:116
msgid "Overlay"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:117
msgid "Multiplies or screens the colors, depending on the backdrop color value. Source colors overlay the backdrop while preserving its highlights and shadows. The backdrop color is not replaced but is mixed with the source color to reflect the lightness or darkness of the backdrop."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:118
msgid "Darken"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:119
msgid "Selects the darker of the backdrop and source colors. The backdrop is replaced with the source where the source is darker; otherwise, it is left unchanged."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:120
msgid "Lighten"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:121
msgid "Selects the lighter of the backdrop and source colors. The backdrop is replaced with the source where the source is lighter; otherwise, it is left unchanged."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:122
msgid "Color dodge"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:123
msgid "Brightens the backdrop color to reflect the source color. Painting with black produces no changes."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:124
msgid "Color burn"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:125
msgid "Darkens the backdrop color to reflect the source color. Painting with white produces no change."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:126
msgid "Hard light"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:127
msgid "Multiplies or screens the colors, depending on the source color value. The effect is similar to shining a harsh spotlight on the backdrop."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:128
msgid "Soft light"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:129
msgid "Darkens or lightens the colors, depending on the source color value. The effect is similar to shining a diffused spotlight on the backdrop."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:130
msgid "Difference"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:131
msgid "Subtracts the darker of the two constituent colors from the lighter color. Painting with white inverts the backdrop color; painting with black produces no change."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:132
msgid "Exclusion"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:133
msgid "Produces an effect similar to that of the Difference mode but lower in contrast. Painting with white inverts the backdrop color; painting with black produces no change."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:134
msgid ":abbr:`HSL(Hue, Saturation, Lightness - Using HSL color space is useful for subtle color changes)` hue"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:135
msgid "Creates a color with the hue of the source color and the saturation and luminosity of the backdrop color."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:136
msgid ":abbr:`HSL(Hue, Saturation, Lightness - Using HSL color space is useful for subtle color changes)` saturation"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:137
msgid "Creates a color with the saturation of the source color and the hue and luminosity of the backdrop color. Painting with this mode in an area of the backdrop that is a pure gray (no saturation) produces no change."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:138
msgid ":abbr:`HSL(Hue, Saturation, Lightness - Using HSL color space is useful for subtle color changes)` color"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:139
msgid "Creates a color with the hue and saturation of the source color and the luminosity of the backdrop color. This preserves the gray levels of the backdrop and is useful for coloring monochrome images or tinting color images."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:140
msgid ":abbr:`HSL(Hue, Saturation, Lightness - Using HSL color space is useful for subtle color changes)` luminosity"
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:141
msgid "Creates a color with the luminosity of the source color and the hue and saturation of the backdrop color. This produces an inverse effect to that of the Color mode."
msgstr ""

#. +> trunk5
#: ../../effects_and_filters/video_effects/generate/cairogradient.rst:151
msgid "For more details see this W3 paper on |blending_modes|"
msgstr ""

